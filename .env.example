# ============================================================
# CollegeCart — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git - it contains sensitive secrets
# ============================================================

# ============================================================
# FRONTEND ENVIRONMENT VARIABLES (Safe to expose in browser)
# ============================================================

# Supabase (required)
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Razorpay PUBLIC Key (safe to expose)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxx

# App URL (for payment redirects)
VITE_APP_URL=http://localhost:5173

# ============================================================
# BACKEND ENVIRONMENT VARIABLES (Supabase Edge Functions)
# Set these in Supabase Dashboard → Edge Functions → Secrets
# NEVER expose these in frontend code
# ============================================================

# Razorpay SECRET Key (NEVER expose in frontend)
# Set via: supabase secrets set RAZORPAY_KEY_SECRET=your_secret_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_key_here

# Razorpay KEY ID (for backend API calls)
# Set via: supabase secrets set RAZORPAY_KEY_ID=your_key_id_here
RAZORPAY_KEY_ID=rzp_test_xxxxx

# Cashfree Credentials (if using Cashfree)
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key

# KYC Verification API (Surepass)
# Sign up at: https://surepass.io → Click "Get API Key"
# Dashboard: https://dashboard.surepass.io
# Sandbox URL: https://sandbox.surepass.io/api/v1
# Production URL: https://kyc-api.surepass.io/api/v1
VITE_KYC_API_KEY=your_surepass_bearer_token
VITE_KYC_BASE_URL=https://sandbox.surepass.io/api/v1

# Supabase Service Role Key (NEVER expose in frontend)
# Set via: supabase secrets set SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Supabase URL (for Edge Functions)
SUPABASE_URL=https://xxxxx.supabase.co

# ============================================================
# DEPLOYMENT INSTRUCTIONS
# ============================================================
# 
# 1. LOCAL DEVELOPMENT:
#    - Copy this file to .env
#    - Fill in your test credentials
#    - Use test keys (rzp_test_) for Razorpay
#
# 2. SUPABASE EDGE FUNCTIONS:
#    - Set secrets via CLI:
#      supabase secrets set RAZORPAY_KEY_SECRET=xxx
#      supabase secrets set RAZORPAY_KEY_ID=xxx
#      supabase secrets set SUPABASE_SERVICE_ROLE_KEY=xxx
#      supabase secrets set SUPABASE_URL=xxx
#
# 3. VERCEL DEPLOYMENT:
#    - Add environment variables in Vercel Dashboard
#    - Only add VITE_* variables (frontend)
#    - Never add secret keys to Vercel
#
# 4. PRODUCTION:
#    - Use live keys (rzp_live_) for Razorpay
#    - Rotate all secrets before going live
#    - Enable webhook signature verification
#
# ============================================================
